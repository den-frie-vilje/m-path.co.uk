{
  "name": "m-path-co-uk",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "og": "tsx scripts/gen-og.ts",
    "photos": "tsx scripts/gen-photos.ts",
    "photos:ci": "bash scripts/gen-photos-docker.sh",
    "prebuild": "tsx scripts/copy-sveltia.ts && tsx scripts/gen-og.ts && tsx scripts/gen-photos.ts"
  },
  "engines": {
    "node": "~25",
    "pnpm": "~10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tensorflow/tfjs-node",
      "esbuild",
      "sharp"
    ]
  },
  "optionalDependencies": {
    "@tensorflow/tfjs-node": "^4.22.0"
  },
  "devDependencies": {
    "@fontsource/jost": "^5.2.5",
    "@fontsource/montserrat": "^5.2.5",
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@sveltia/cms": "0.157.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@upscalerjs/esrgan-thick": "^1.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.35.2",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "upscaler": "^1.0.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "dompurify": "^3.2.4",
    "marked": "^18.0.5"
  }
}
