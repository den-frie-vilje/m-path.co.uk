# Postgres connection (drizzle + postgres.js). Matches deploy/compose.dev.yml.
DATABASE_URL="postgres://mpath:mpath@localhost:5433/mpath"

# Public origin of the deployment (used by Better Auth + SvelteKit CSRF in prod).
# Leave empty in dev — the request origin is inferred.
ORIGIN=""

# Better Auth session secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Bootstrap admin — created on first `pnpm db:seed` if no users exist.
ADMIN_EMAIL="admin@m-path.co.uk"
ADMIN_PASSWORD="change-me-in-production"

# Build metadata (baked into the footer). CI supplies these.
PUBLIC_GIT_SHA=""
PUBLIC_BUILD_TIME=""
